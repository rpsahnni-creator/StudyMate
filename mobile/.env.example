# Copy to .env and set your PC's LAN IP (same Wi-Fi as your phone).
#   copy .env.example .env
#
# Find IP:  ipconfig   →  IPv4 Address (e.g. 192.168.1.5)
# If phone cannot connect, allow Windows Firewall TCP port 8080 or run backend/scripts/bootstrap-dev.ps1 as Admin.
EXPO_PUBLIC_API_URL=http://192.168.1.5:8080
